rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSeahUser() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.lower().matches('.*@seah\\.co\\.kr$');
    }

    function isWarrantyGuideAdmin() {
      return isSeahUser()
        && request.auth.token.email.lower() == 'chaelynn.kim@seah.co.kr';
    }

    match /warranty-attachments/{allPaths=**} {
      allow read, write: if isSeahUser();
    }

    match /warranty-guide/{allPaths=**} {
      allow read: if isSeahUser();
      allow write: if isWarrantyGuideAdmin();
    }
  }
}
