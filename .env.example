# Firebase (Google 로그인 + Firestore) — 미설정 시 firebase.embedded.ts 폴백 사용
# Firestore 컬렉션: app-data (firestore.rules 참고)
# 실제 키는 .env 에만 넣으세요 (.env.example 은 Git에 올라갈 수 있음)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# EmailJS — 의뢰/발행완료 알림 (빌드·배포 시 필수. 비우면 메일이 발송되지 않음)
# https://dashboard.emailjs.com 에서 Service / Template / Public Key 확인
# 배포: .env 작성 후 npm run build && npm run deploy:hosting
# 또는 src/lib/emailjs.embedded.ts 에 동일 값을 넣어도 됩니다.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_COMPLETED_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# 사이트 URL (메일 링크 — 미설정 시 Firebase Hosting 기본 주소)
VITE_SITE_URL=https://warranty-management-common.web.app

# 보증서 PDF 변환 서버 (LibreOffice — PPTX 양식 그대로 PDF 생성)
# Cloud Run: https://pptx-to-pdf-converter-688570818869.asia-northeast3.run.app
# 로컬: docker compose up 후 http://localhost:8080
# 미설정 시 src/lib/pptxToPdf.embedded.ts 폴백 사용
VITE_PPTX_TO_PDF_API_URL=
# 선택: 변환 서버 API 키 (서버 API_KEY 와 동일)
VITE_PPTX_TO_PDF_API_KEY=
